    "aesthetic_turbo_conversion": "in-memory; root prefix normalized model.diffusion_model.->net. (upstream convert is base-only: hardcodes net.llm_adapter. and PREFIX_KEY='net.').",
    "regen_command": "ANIMA_CONVERT_DIR=<dir> <venv>/bin/python mlx-gen-anima/tests/fixtures/gen_anima_stage7_golden.py",
    "generator": "mlx-gen-anima/tests/fixtures/gen_anima_stage7_golden.py",
    "prompt": "an anime girl with long silver hair and blue eyes, detailed illustration, masterpiece",
    "negative": "",
